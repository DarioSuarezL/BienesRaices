extends ../layout/index.pug

block content
    div(class="py-10")
        h1(class="text-center text-4xl font-bold my-10") Bienes
            span(class="font-normal") Raices
        h2(class="text-center text-2xl font-bold")= title

        div(class="text-center text-gray-400 my-5 w-1/3 mx-auto")
            span Por favor, ingresa tu correo electrónico para enviarte las instrucciones de recuperación de contraseña.

        div(class="mt-8 mx-auto max-w-md")
            div(class="bg-white py-8 px-4 shadow rounded-lg")
                form(action="")
                    div(class="flex flex-col gap-3")
                        //- label(class="block text-gray-500 text-sm font-bold mb-2 uppercase" for="nombre") Nombre
                        input(class="w-full px-5 py-3 border border-gray-300 rounded-lg" type="email" id="email" placeholder="Correo electrónico")
                        div(class="flex justify-between")
                            a(class="text-sm text-gray-600 hover:text-gray-400 hover:cursor-pointer hover:underline" href="/auth/login") Iniciar sesión
                        input(class="text-white font-bold py-2 w-full bg-blue-700 hover:bg-blue-600 rounded-lg hover:cursor-pointer" type="submit" value="Enviar instrucciones")